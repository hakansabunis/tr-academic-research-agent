# ── LLM sağlayıcısı (PROVIDER-INDEPENDENT) ──
# Varsayılan: DeepSeek (aşağıdaki DEEPSEEK_*). Başka herhangi bir
# OpenAI-uyumlu sağlayıcı için LLM_* set et (DEEPSEEK_*'ı override eder):
#
#   OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1
#                LLM_API_KEY=sk-or-...   LLM_MODEL=meta-llama/llama-3.1-70b-instruct
#   OpenAI:      LLM_BASE_URL=https://api.openai.com/v1
#                LLM_API_KEY=sk-...      LLM_MODEL=gpt-4o-mini
#   Lokal (Ollama/vLLM/LM Studio — DeepSeek'siz, offline, ücretsiz):
#                LLM_BASE_URL=http://localhost:11434/v1
#                LLM_MODEL=qwen2.5:7b    (key gerekmez)
# Not: pipeline structured-output için tool/function-calling kullanır →
# tool-calling destekleyen bir model seç (Ollama'da qwen2.5 / llama3.1 vb.).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Tüm veriyi OneDrive dışı bir yere yönlendir (14+ GB indeksin OneDrive'a
# senkron edilmesini önler). Boş bırakılırsa proje altındaki `data/` kullanılır.
DATA_DIR=C:\dev\turk-researcher-data

# ─────────────────────────────────────────────────────────────────────────
# ÜRÜN VARSAYILANLARI = ölçülen EN İYİ sistem. Hiçbirini set etmesen de
# kod bu değerleri varsayar; burada sadece görünür/değiştirilebilir olsun.
#
#   trakad-embed-v2 retriever  → +%9.9 citation accuracy (ölçüldü)
#   chroma_db_v2 indeksi       → v2 embedder ile yeniden kuruldu
#   reranker ON                → +0.09 citation accuracy (30-soru A/B)
#   live search OFF            → ölçülen sistemle tutarlı (İngilizce API gürültüsü yok)
# ─────────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=hakansabunis/trakad-embed-v2
# Boş → DATA_DIR/chroma_db_v2 (ürün). v1 baseline için DATA_DIR/chroma_db ver.
CHROMA_PERSIST_DIR=
CHROMA_COLLECTION=turkish_theses
HF_INDEX_REPO=hakansabunis/tr-academic-research-agent-index

TRRESEARCHER_RERANK=1
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_TOP_N=10
TRRESEARCHER_LIVE=0

# ── v1/baseline'ı yeniden üretmek (paper ablation) için: ──
#   EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
#   CHROMA_PERSIST_DIR=<DATA_DIR>\chroma_db
#   TRRESEARCHER_RERANK=0

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=turk-researcher
